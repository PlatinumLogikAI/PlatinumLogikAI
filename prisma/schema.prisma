generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model PromptSession {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  mode        String
  input       String
  rawPrompt   String
  shotsJson   String?
  worldId     String?
  world       WorldBible? @relation(fields: [worldId], references: [id])
}

model WorldBible {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  name        String   @unique
  palette     String
  era         String
  themes      String
  styleNotes  String?
  sessions    PromptSession[]
}
